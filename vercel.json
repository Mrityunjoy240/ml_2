{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/linearlearn build",
  "outputDirectory": "artifacts/linearlearn/dist/public",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

